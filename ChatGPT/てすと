Sub ReplaceTextInPowerPointTables()
    ' PowerPointのオブジェクトを宣言
    Dim pptApp As Object
    Dim pptPres As Object
    Dim pptSlide As Object
    Dim pptShape As Object
    Dim pptTable As Object
    
    ' PowerPointを起動
    Set pptApp = CreateObject("PowerPoint.Application")
    pptApp.Visible = True
    
    ' PowerPointのテンプレートを開く
    Set pptPres = pptApp.Presentations.Open("C:\Path\To\Your\Template.pptx")
    
    ' 確認したいスライドを取得
    Set pptSlide = pptPres.Slides(1) ' 例として1ページ目のスライド
    
    ' スライドのすべてのテーブルをチェックし、値を置き換える
    Dim shapeIndex As Integer
    Dim rowIndex As Integer
    Dim colIndex As Integer
    
    For shapeIndex = 1 To pptSlide.Shapes.Count
        Set pptShape = pptSlide.Shapes(shapeIndex)
        If pptShape.HasTable Then
            Set pptTable = pptShape.Table
            For rowIndex = 1 To pptTable.Rows.Count
                For colIndex = 1 To pptTable.Columns.Count
                    ' セルの値をデバッグログに出力
                    Debug.Print "Table " & shapeIndex & " - Cell(" & rowIndex & "," & colIndex & "): " & pptTable.Cell(rowIndex, colIndex).Shape.TextFrame.TextRange.Text
                    
                    ' 特定の文字列を置き換える
                    pptTable.Cell(rowIndex, colIndex).Shape.TextFrame.TextRange.Text = Replace(pptTable.Cell(rowIndex, colIndex).Shape.TextFrame.TextRange.Text, "OldValue", "NewValue")
                Next colIndex
            Next rowIndex
        End If
    Next shapeIndex
    
    ' クリーンアップ
    pptPres.Close
    pptApp.Quit
    Set pptApp = Nothing
    Set pptPres = Nothing
    Set pptSlide = Nothing
    Set pptShape = Nothing
    Set pptTable = Nothing
End Sub
