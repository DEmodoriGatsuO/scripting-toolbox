Sub TestPowerPointTextFrame()
    ' PowerPointのオブジェクトを宣言
    Dim pptApp As Object
    Dim pptPres As Object
    Dim pptSlide As Object
    Dim pptShape As Object
    
    ' PowerPointを起動
    Set pptApp = CreateObject("PowerPoint.Application")
    pptApp.Visible = True
    
    ' PowerPointのテンプレートを開く
    Set pptPres = pptApp.Presentations.Open("C:\Path\To\Your\Template.pptx")
    
    ' 確認したいスライドを取得
    Set pptSlide = pptPres.Slides(1) ' 例として1ページ目のスライド
    
    ' スライドのすべてのテキストフレームをチェックし、デバッグログに出力する
    Dim shapeIndex As Integer
    For shapeIndex = 1 To pptSlide.Shapes.Count
        Set pptShape = pptSlide.Shapes(shapeIndex)
        If pptShape.HasTextFrame Then
            If pptShape.TextFrame.HasText Then
                Debug.Print "Shape " & shapeIndex & ": " & pptShape.TextFrame.TextRange.Text
            Else
                Debug.Print "Shape " & shapeIndex & ": No text in text frame"
            End If
        Else
            Debug.Print "Shape " & shapeIndex & ": No text frame"
        End If
    Next shapeIndex
    
    ' クリーンアップ
    pptPres.Close
    pptApp.Quit
    Set pptApp = Nothing
    Set pptPres = Nothing
    Set pptSlide = Nothing
    Set pptShape = Nothing
End Sub
